{
  "name": "tanstarter-template",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "auto-import",
    "bun",
    "monorepo",
    "react",
    "shadcn",
    "tailwind",
    "tanstack",
    "tanstack-start",
    "typescript",
    "vite",
    "vite-plus"
  ],
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "dev": "turbo run dev --filter=@repo/web --filter=@repo/convex",
    "dev:web": "vp run web#dev",
    "dev:convex": "vp run convex#dev",
    "start": "vp run web#start",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "1.3.13",
    "turbo": "^2.9.4",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.11",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest",
    "typescript": "^6",
    "tailwindcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@tabler/icons-react": "^3.41.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "@base-ui/react": "^1.3.0",
    "tw-animate-css": "^1.4.0",
    "shadcn": "^4.1.2",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "zod": "^4.3.6"
  }
}