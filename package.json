{
  "name": "tanstarter-template",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "dev": "turbo run dev --filter=@repo/web --filter=@repo/backend",
    "dev:web": "vp run web#dev",
    "dev:convex": "vp run convex#dev",
    "start": "vp run web#start",
    "prepare": "vp config",
    "build": "vp run web#build"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "1.3.14",
    "turbo": "^2.9.4",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24",
    "vite-plus": "0.1.24",
    "typescript": "^6",
    "tailwindcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@tabler/icons-react": "^3.41.1",
    "@base-ui/react": "^1.5.0",
    "tw-animate-css": "^1.4.0",
    "shadcn": "^4.10.0"
  }
}